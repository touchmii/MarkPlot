{
  "name": "markplot",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "可扩展的打印图样生成器：坐标测量靶 / 工业二维码等，按毫米精确出图，支持 A4 多图排版。",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
